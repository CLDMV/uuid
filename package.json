{
	"name": "@cldmv/uuid",
	"version": "1.1.1",
	"description": "Extended RFC 4122 and RFC 9562 UUID implementation with custom variant structures, issuer-based identification, and timestamp variants",
	"main": "./index.cjs",
	"module": "./index.mjs",
	"types": "./types/index.d.mts",
	"exports": {
		".": {
			"types": "./types/index.d.mts",
			"import": "./index.mjs",
			"require": "./index.cjs"
		},
		"./devcheck": {
			"types": "./types/devcheck.d.mts",
			"import": "./devcheck.mjs"
		},
		"./main": {
			"uuid-dev": {
				"import": "./src/uuid.mjs"
			},
			"import": "./dist/uuid.mjs"
		}
	},
	"type": "module",
	"engines": {
		"node": ">=16.12.0"
	},
	"scripts": {
		"build": "npm run build:dist && npm run build:types",
		"build:dist": "node -e \"const fs = require('fs'); const path = require('path'); fs.rmSync('dist', {recursive: true, force: true}); fs.mkdirSync('dist', {recursive: true}); fs.cpSync('src', 'dist', {recursive: true});\"",
		"build:types": "node -e \"require('fs').rmSync('types', {recursive: true, force: true})\" && tsc --project .configs/tsconfig.dts.jsonc",
		"demo": "node scripts/demo-custom-uuids.mjs",
		"test": "vitest run --config .configs/vitest.config.mjs",
		"test:watch": "vitest --config .configs/vitest.config.mjs",
		"coverage": "npm run test:coverage",
		"test:coverage": "vitest run --coverage --config .configs/vitest.config.mjs",
		"fix:headers": "node tools/fix-headers.mjs",
		"types:build": "tsc -p .configs/tsconfig.json --noCheck",
		"types:check": "tsc -p .configs/tsconfig.json --noEmit"
	},
	"keywords": [
		"uuid",
		"guid",
		"rfc4122",
		"identifier",
		"custom-uuid",
		"timestamp",
		"issuer",
		"variant",
		"entropy",
		"collision-resistant",
		"nodejs",
		"esm"
	],
	"author": {
		"name": "Shinrai",
		"company": "CLDMV",
		"email": "git+npm@cldmv.net",
		"url": "https://cldmv.net"
	},
	"contributors": [
		{
			"name": "CLDMV",
			"url": "https://github.com/CLDMV"
		}
	],
	"license": "Apache-2.0",
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/shinrai"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CLDMV/uuid.git"
	},
	"bugs": {
		"url": "https://github.com/CLDMV/uuid/issues"
	},
	"homepage": "https://github.com/CLDMV/uuid#readme",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"index.mjs",
		"index.cjs",
		"README.md",
		"LICENSE",
		"types/dist/",
		"types/index.d.mts",
		"types/index.d.mts.map",
		"dist/"
	],
	"sideEffects": false,
	"devDependencies": {
		"@cldmv/fix-headers": "^1.2.2",
		"@vitest/coverage-v8": "^4.0.18",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
